# Ignore everything by default at the repo root.
/*

#Explicitly ignoring the docker related files
.secrets
.act-cache/

# Explicitly ignore raw source archives/workbooks.
/data/staging

# Explicitly ignoring the scripts
/scripts
/.github
/oldPython
/pipeline

# Keep this file itself.
!/.gitignore
!/.github/
!/.github/workflows/
!/.github/workflows/discord-notify.yml
!/.github/workflows/drive-data-sync-pipeline.yml
!/.github/workflows/drive-data-sync-pipeline-test.yml

# Keep the pipeline workflow
!/pipeline/
!/pipeline/**
/pipeline/__pycache__/
/pipeline/*.pyc
/pipeline/node_modules
/pipeline/output/
/pipeline/github-actions-service-account.json
/pipeline/pipeline-config.json
/pipeline/pipeline-state.json
/pipeline/pipeline-run-summary.json
/pipeline/pipeline-watch-state.json

# Keep the app entrypoint.
!/index.html
!/favicon.svg

# Keep the test thumbnail page.
!/test-thumbnail.html

# Keep source folders.
!/css/
!/css/**
!/js/
!/js/**
!/data/
!/data/**

#Keep the thumbnail
!/thumbnail.png

# Ignore non-runtime data metadata/docs.
/data/README.md
/data/import-summary.json

# Ignore generated staging outputs inside the tracked data folder.
/data/staging/
/data/staging/**

# Ignore legacy full matchup data files
/data/matchups.json
/js/matchups-data.js

