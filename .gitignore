# Ignore everything by default at the repo root.
/*

# Explicitly ignore raw source archives/workbooks.
/data/staging

# Explicitly ignoring the scripts
/scripts
/.github
/oldPython

# Keep this file itself.
!/.gitignore
!/.github/
!/.github/workflows/
!/.github/workflows/discord-notify.yml
!/.github/workflows/drive-data-sync-pipeline.yml

!/scripts/
/scripts/**
!/scripts/automatedpipeline/
!/scripts/automatedpipeline/**
/scripts/automatedpipeline/__pycache__/
/scripts/automatedpipeline/*.pyc
/scripts/automatedpipeline/output/
/scripts/automatedpipeline/github-actions-service-account.json
/scripts/automatedpipeline/pipeline-config.json
/scripts/automatedpipeline/pipeline-state.json
/scripts/automatedpipeline/pipeline-run-summary.json
/scripts/automatedpipeline/pipeline-watch-state.json

# Keep the app entrypoint.
!/index.html
!/favicon.svg

# Keep source folders.
!/css/
!/css/**
!/js/
!/js/**
!/data/
!/data/**

#Keep the thumbnail
!/thumbnail.png

# Ignore non-runtime data metadata/docs.
/data/README.md
/data/import-summary.json

# Ignore generated staging outputs inside the tracked data folder.
/data/staging/
/data/staging/**

# Ignore legacy full matchup data files
/data/matchups.json
/js/matchups-data.js

