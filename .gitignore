# Ignore everything by default at the repo root.
/*

# Explicitly ignore raw source archives/workbooks.
/data/staging

# Explicitly ignoring the scrips
/scripts
/oldPython

# Keep this file itself.
!/.gitignore

# Keep the app entrypoint.
!/index.html
!/favicon.svg

# Keep source folders.
!/css/
!/css/**
!/js/
!/js/**
!/data/
!/data/**

#Keep the thumbnail
!/thumbnail.png

# Ignore non-runtime data metadata/docs.
/data/README.md
/data/import-summary.json

# Ignore generated staging outputs inside the tracked data folder.
/data/staging/
/data/staging/**

# Ignore legacy full matchup data files
/data/matchups.json
/js/matchups-data.js

